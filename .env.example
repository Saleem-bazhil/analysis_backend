# Copy this file to .env and update values for your environment

# ── Database ──
DATABASE_URL=postgresql://analysis:yourpassword@db:5432/analysis

# ── Redis (required for real-time WebSocket sync) ──
REDIS_URL=redis://:yourpassword@redis:6379/0

# ── Django ──
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=analysis.systimus.in

# ── CORS / CSRF ──
CORS_ALLOWED_ORIGINS=https://analysisreport.systimus.in
CSRF_TRUSTED_ORIGINS=https://analysisreport.systimus.in

# ── User Passwords (used by seed_users management command) ──
ADMIN_PASSWORD=Admin@123
SALEEM_PASSWORD=Saleem@123
OPERATOR_PASSWORD=Operator@123
